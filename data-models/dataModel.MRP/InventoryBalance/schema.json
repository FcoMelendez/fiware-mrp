{
  "$schema": "http://json-schema.org/schema#",
  "$schemaVersion": "0.2.0",
  "modelTags": "MRP",
  "$id": "https://smart-data-models.github.io/dataModel.MRP/InventoryBalance/schema.json",
  "title": "Smart Data Models - MRP InventoryBalance",
  "description": "The current on-hand quantity of a specific product at a specific stock location. A balance is updated by every StockMove that affects the product/location combination. When lot tracking is active, a separate balance exists per lot.",
  "type": "object",
  "allOf": [
    {
      "properties": {
        "id": {
          "type": "string",
          "format": "uri",
          "pattern": "^urn:ngsi-ld:InventoryBalance:.+",
          "description": "Unique identifier. Recommended format: urn:ngsi-ld:InventoryBalance:IB-{ProductCode}-{LocationCode}[-{LotCode}]"
        },
        "type": {
          "type": "string",
          "enum": ["InventoryBalance"],
          "description": "NGSI-LD Entity type. Must be InventoryBalance."
        },
        "quantityOnHand": {
          "type": "object",
          "required": ["type", "value"],
          "properties": {
            "type": { "type": "string", "const": "Property" },
            "value": { "type": "number", "minimum": 0 },
            "unitCode": { "type": "string", "description": "UN/CEFACT unit code (e.g. EA, KGM, LTR)." }
          },
          "description": "Total quantity physically present at the location, regardless of reservation status."
        },
        "reservedQuantity": {
          "type": "object",
          "required": ["type", "value"],
          "properties": {
            "type": { "type": "string", "const": "Property" },
            "value": { "type": "number", "minimum": 0 },
            "unitCode": { "type": "string" }
          },
          "description": "Quantity committed to open manufacturing orders or transfers. Cannot exceed quantityOnHand."
        },
        "availableQuantity": {
          "type": "object",
          "required": ["type", "value"],
          "properties": {
            "type": { "type": "string", "const": "Property" },
            "value": { "type": "number" },
            "unitCode": { "type": "string" }
          },
          "description": "Quantity available for new consumption or reservation (quantityOnHand minus reservedQuantity)."
        },
        "inventoryDate": {
          "type": "object",
          "required": ["type", "value"],
          "properties": {
            "type": { "type": "string", "const": "Property" },
            "value": { "type": "string", "format": "date-time" }
          },
          "description": "ISO 8601 timestamp of the last balance update."
        },
        "state": {
          "type": "object",
          "required": ["type", "value"],
          "properties": {
            "type": { "type": "string", "const": "Property" },
            "value": {
              "type": "string",
              "enum": ["active", "frozen"],
              "description": "active: normal availability; frozen: location under inventory count, no movements allowed."
            }
          },
          "description": "Operational state of the balance record."
        },
        "product": {
          "type": "object",
          "required": ["type", "object"],
          "properties": {
            "type": { "type": "string", "const": "Relationship" },
            "object": { "type": "string", "format": "uri", "pattern": "^urn:ngsi-ld:Product:.+" }
          },
          "description": "Reference to the Product whose quantity is tracked."
        },
        "location": {
          "type": "object",
          "required": ["type", "object"],
          "properties": {
            "type": { "type": "string", "const": "Relationship" },
            "object": { "type": "string", "format": "uri", "pattern": "^urn:ngsi-ld:StockLocation:.+" }
          },
          "description": "Reference to the StockLocation where the stock physically resides."
        },
        "lot": {
          "type": "object",
          "required": ["type", "object"],
          "properties": {
            "type": { "type": "string", "const": "Relationship" },
            "object": { "type": "string", "format": "uri", "pattern": "^urn:ngsi-ld:Lot:.+" }
          },
          "description": "Reference to the Lot. Present only when the product is lot-tracked."
        }
      }
    }
  ],
  "required": ["id", "type", "quantityOnHand", "inventoryDate", "state", "product", "location"],
  "@context": [
    "http://context-server:3000/contexts/mrp/v0.1/context.jsonld"
  ]
}
